# Cấu hình biến môi trường cho quá trình biên dịch (Build)
# Đổi tên file này thành `.env` để sử dụng.

# GOOGLE_CLIENT_ID: Cần thiết cho tính năng Đồng bộ Google Drive.
# Lấy từ Google Cloud Console (APIs & Services > Credentials > OAuth 2.0 Client IDs).
# Ứng dụng dùng loại "TV and Limited Input" (Device Authorization Grant).
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
VNKEY_SYNC_PASSWORD=your_secure_sync_password_here